PORT=4000
NODE_ENV=development
APP_NAME=SVP Backend API

# Frontend URL(s) for CORS (comma separated)
CORS_ORIGINS=http://localhost:3000
# Optional: allow Vercel preview URLs like https://<hash>-<project>-<team>.vercel.app
VERCEL_PROJECT_SLUG=
# Note: *.lovable.app and *.lovableproject.com are auto-allowed in code.

# Your backend JWT
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=14

# Cookie
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Database (Postgres)
# Local machine: use Railway public proxy URL if you want to develop against the live database.
DATABASE_URL="postgresql://postgres:your-password@switchback.proxy.rlwy.net:39012/railway"
DATABASE_PUBLIC_URL="postgresql://postgres:your-password@switchback.proxy.rlwy.net:39012/railway"

# SVP API
SVP_BASE_URL="https://svp-international-api.pacc.sa"
SVP_LOCALE="en"
SVP_FE_APP="legislator"
REQUIRE_PORTAL_APPROVAL=false

# Encryption key (32 bytes base64 recommended)
SESSION_ENC_KEY_BASE64=

# Optional seeded admin account for the local portal approval layer
ADMIN_SEED_LOGIN=admin
ADMIN_SEED_PASSWORD=admin
ADMIN_SEED_EMAIL=abdurrazzak7395@gmail.com
ADMIN_SEED_NAME=ABDUR RAZZAK

# Railway notes:
# - Railway injects PORT automatically in production.
# - Railway injects RAILWAY_PUBLIC_DOMAIN automatically in production.
# - Do not set the RAILWAY_* variables manually.
#
# Live Railway example:
# NODE_ENV=production
# APP_NAME=SVP Backend API
# CORS_ORIGINS=https://svp-book.vercel.app,https://svp-book-abdur-razzak-s-projects.vercel.app
# VERCEL_PROJECT_SLUG=svp-book
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# DATABASE_URL=postgresql://postgres:your-password@postgres.railway.internal:5432/railway
# SVP_BASE_URL=https://svp-international-api.pacc.sa
# SVP_LOCALE=en
# SVP_FE_APP=legislator
